    <bpmn:userTask id="UserTask_145m6aa" name="Lançamento das Despesas Reais" implementation="##unspecified">
      <bpmn:extensionElements />
      <bpmn:incoming>SequenceFlow_1p1kg8t</bpmn:incoming>
      <bpmn:outgoing>SequenceFlow_0gjirzc</bpmn:outgoing>
